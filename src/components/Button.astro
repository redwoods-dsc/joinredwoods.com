---
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost' | 'danger';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  class?: string;
  [key: string]: unknown;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  disabled,
  class: className,
  ...rest
} = Astro.props;

const Tag = href ? 'a' : 'button';
---

<Tag
  class:list={['btn', className]}
  data-variant={variant}
  data-size={size}
  href={href}
  type={href ? undefined : type}
  disabled={href ? undefined : disabled}
  aria-disabled={href && disabled ? 'true' : undefined}
  {...rest}
>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs);
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    font-family: inherit;
    font-weight: var(--font-weight-medium);
    line-height: 1;
    text-decoration: none;
    cursor: pointer;
    transition:
      background-color var(--motion-duration-fast) var(--motion-ease-standard),
      border-color var(--motion-duration-fast) var(--motion-ease-standard),
      color var(--motion-duration-fast) var(--motion-ease-standard),
      transform var(--motion-duration-fast) var(--motion-ease-standard);
  }

  .btn:where(:not(:disabled, [aria-disabled='true'])):active {
    transform: translateY(1px);
  }

  .btn:disabled,
  .btn[aria-disabled='true'] {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .btn[data-size='sm'] {
    padding: var(--space-xs) var(--space-sm);
    font-size: var(--font-size-sm);
  }

  .btn[data-size='md'] {
    padding: var(--space-sm) var(--space-md);
    font-size: var(--font-size-base);
  }

  .btn[data-size='lg'] {
    padding: var(--space-md) var(--space-lg);
    font-size: var(--font-size-md);
  }

  .btn[data-variant='primary'] {
    background-color: var(--color-accent);
    color: var(--color-accent-contrast);
  }

  .btn[data-variant='primary']:where(:not(:disabled, [aria-disabled='true'])):hover {
    background-color: color-mix(in srgb, var(--color-accent) 85%, var(--color-neutral-1000));
  }

  .btn[data-variant='secondary'] {
    background-color: var(--color-neutral-0);
    color: var(--color-text);
    border-color: var(--color-border);
  }

  .btn[data-variant='secondary']:where(:not(:disabled, [aria-disabled='true'])):hover {
    background-color: var(--color-surface);
    border-color: var(--color-neutral-300);
  }

  .btn[data-variant='ghost'] {
    background-color: transparent;
    color: var(--color-text);
  }

  .btn[data-variant='ghost']:where(:not(:disabled, [aria-disabled='true'])):hover {
    background-color: var(--color-surface);
  }

  .btn[data-variant='danger'] {
    background-color: #b91c1c;
    color: var(--color-neutral-0);
  }

  .btn[data-variant='danger']:where(:not(:disabled, [aria-disabled='true'])):hover {
    background-color: #991b1b;
  }
</style>
